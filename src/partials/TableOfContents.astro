---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  tocHeadings.length > 1 && (
    <nav id="toc" class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto rounded-lg bg-slate-800 p-4 text-sm">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-gray-400">
        Contents
      </p>
      <ul class="space-y-0.5">
        {tocHeadings.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                'toc-link block rounded py-1 leading-snug text-gray-400 transition-colors hover:text-cyan-400',
                h.depth === 3 ? 'pl-4 text-xs' : 'pl-1',
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  const headingElements = document.querySelectorAll<HTMLElement>('h2[id], h3[id]');
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');

  if (headingElements.length && tocLinks.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('text-cyan-400', 'font-medium'));
            const active = document.querySelector<HTMLAnchorElement>(
              `.toc-link[href="#${entry.target.id}"]`
            );
            active?.classList.add('text-cyan-400', 'font-medium');
            break;
          }
        }
      },
      { rootMargin: '-8% 0px -80% 0px', threshold: 0 }
    );

    headingElements.forEach((el) => observer.observe(el));
  }
</script>
