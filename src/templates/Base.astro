---
import { Footer } from '@/partials/Footer';
import { Navbar } from '@/partials/Navbar';
import SearchModal from '@/partials/SearchModal.astro';
import { AppConfig } from '@/utils/AppConfig';
import '@/styles/global.css';

export interface Props {
  head: {
    title: string;
    description: string;
    ogImage?: string;
  };
}

const {
  head: { title, description, ogImage },
} = Astro.props as Props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteOgImage = ogImage
  ? ogImage.startsWith('http')
    ? ogImage
    : Astro.site
      ? new URL(ogImage, Astro.site).href
      : ogImage
  : undefined;
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta name='author' content={AppConfig.author} />
    <link rel='canonical' href={canonicalURL} />

    <!-- Open Graph -->
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalURL} />
    <meta property='og:site_name' content={AppConfig.site_name} />
    {absoluteOgImage && <meta property='og:image' content={absoluteOgImage} />}
    <meta property='og:type' content='website' />

    <!-- Twitter Card -->
    <meta name='twitter:card' content={absoluteOgImage ? 'summary_large_image' : 'summary'} />
    <meta name='twitter:site' content='@FireEyesOMG' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    {absoluteOgImage && <meta name='twitter:image' content={absoluteOgImage} />}

    <link rel='alternate' type='application/rss+xml' href='/rss.xml' />
    <link rel='icon' type='image/x-icon' href='/favicon.ico' />

  </head>
  <body class='bg-slate-900 text-gray-100'>
    <Navbar />
    <SearchModal />

    <slot></slot>

    <!-- <Footer /> -->

    <script>
      function addCopyButtons() {
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.querySelector('.copy-btn')) return;
          const btn = document.createElement('button');
          btn.textContent = 'Copy';
          btn.className = 'copy-btn';
          pre.appendChild(btn);
          btn.addEventListener('click', async () => {
            const text = pre.querySelector('code')?.textContent ?? '';
            await navigator.clipboard.writeText(text);
            btn.textContent = 'Copied!';
            btn.classList.add('copied');
            setTimeout(() => {
              btn.textContent = 'Copy';
              btn.classList.remove('copied');
            }, 2000);
          });
        });
      }
      addCopyButtons();
      document.addEventListener('astro:after-swap', addCopyButtons);
    </script>
  </body>
</html>
